{
    "layer": "top",
    "height": 35, // Waybar height (to be removed for auto height)
    "margin-top": 0,
    "margin-left": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "spacing": 3,
    "modules-left": ["wlr/workspaces"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "battery", "pulseaudio", "backlight", "bluetooth", "network",  "clock"],
    "wlr/workspaces": {
      "format": "{name}",
      "on-click": "activate",
      "format-icons": {
        "1": "ΎΕΣ",
        "2": "ΎΕΣ",
        "3": "ΎΕΣ",
        "4": "ΎΕΣ",
        "5": "ΎΕΣ",
        "urgent": "ΎΒς",
        "active": "ΎΕΣ",
        "default": "ΎΕΣ"
      }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "{:%B %d, %I:%M %p}"
    },

    "cpu": {
      "interval": 1,
      "format": "Ύαο {usage}%",
      "max-length": 100,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "Ύας {}%",
        "format-alt":"ΎΣ▓ {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    },
    "network": {
        "format-wifi": "Ύςρ",
        "format-ethernet": "Ύδ┐ wired",
        "format-disconnected": "Ύςσ",
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "ΎΑξ ΎΛΦ",
        "format-bluetooth-muted": "ΎςΑ ΎΛΦ",
        "format-muted": "ΎςΑ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "bluetoothctl connect FC:58:FA:42:3D:D8"
    },

    "bluetooth": {
        "format": "ΎΛΦ",
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span color='#3bd7a0' font-family='Font Awesome 6 Free'>ΎΔπ</span> {capacity}%",
      "format-plugged": "ΎΘο  {capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "ΎΘο  {capacity}%",
      "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
    },
}

