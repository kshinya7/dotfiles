{
    "layer": "top",
    "height": 35, // Waybar height (to be removed for auto height)
    "margin-top": 0,
    "margin-left": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "spacing": 3,
    "modules-left": ["wlr/workspaces"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "pulseaudio", "battery", "backlight", "bluetooth", "network",  "clock"],
    "wlr/workspaces": {
      "format": "{name}",
      "on-click": "activate",
      "format-icons": {
        "1": "яДС",
        "2": "яДС",
        "3": "яДС",
        "4": "яДС",
        "5": "яДС",
        "urgent": "яБк",
        "active": "яДС",
        "default": "яДС"
      }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "{:%B %d, %I:%M %p}"
    },

    "cpu": {
      "interval": 1,
      "format": "яШж {usage}%",
      "max-length": 100,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "яШк {}%",
        "format-alt":"яС▓ {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon}",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
    },
    "network": {
        "format-wifi": "яки",
        "format-ethernet": "яЫ┐ wired",
        "format-disconnected": "якй",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яАе яКФ {volume}%",
        "format-bluetooth-muted": "якА яКФ",
        "format-muted": "якА",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "bluetoothctl connect FC:58:FA:42:3D:D8"
    },

    "bluetooth": {
        "format": "яКФ",
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span color='#3bd7a0' font-family='Font Awesome 6 Free'>яГз</span> {capacity}%",
      "format-plugged": "яЗж  {capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "яЗж  {capacity}%",
      "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "],
    },
}

